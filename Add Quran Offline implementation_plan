### Layer 5 — Repository (Modified)

#### [MODIFY] [QuranRepository.kt](file:///D:/AI/Projects With AI/Islamic App/Muslim Companion V1/muslim-companion/app/src/main/java/com/example/data/repository/QuranRepository.kt)

Add an **`OfflineQuranRepository`** class that implements the existing
`QuranRepository` interface. The interface itself stays **unchanged** so all
ViewModels continue to work without modification.

```kotlin
class OfflineQuranRepository(
    private val dao: CompanionDao,
    private val assetLoader: QuranAssetLoader,
    private val quranInfo: QuranInfo
) : QuranRepository {

    // Returns hardcoded SurahMetadata as Flow<List<Surah>>
    override fun getSurahsFlow(): Flow<List<Surah>> = flow {
        emit(SurahMetadata.ALL.map { it.toDomain() })
    }

    override suspend fun getSurahsDirect(): List<Surah> =
        SurahMetadata.ALL.map { it.toDomain() }

    // No-op: surahs are hardcoded, nothing to refresh
    override suspend fun refreshSurahs() {
        if (!assetLoader.isSeeded()) assetLoader.seedDatabase()
    }

    override fun getAyahsForSurahFlow(surahNumber: Int, reciter: String): Flow<List<Ayah>> =
        flow {
            val entities = dao.getAyahsForSura(surahNumber)
            emit(entities.map { it.toDomain(surahNumber, reciter) })
        }

    // Seeds DB from assets if needed, no network call
    override suspend fun refreshAyahs(surahNumber: Int, reciter: String) {
        if (!assetLoader.isSeeded()) assetLoader.seedDatabase()
    }

    override suspend fun getSurahWithAudio(...): List<CachedAyahEntity> {
        // Build audio URL from predictable pattern (see Audio section below)
        // No network call for text; optional network call for audio URL only
    }

    // Bookmark methods delegate to DAO unchanged
    override fun getBookmarksFlow() = dao.getBookmarksFlow()
    override suspend fun toggleBookmark(surahNumber: Int, surahName: String) { ... }
    override fun isBookmarkedFlow(surahNumber: Int) = dao.isBookmarkedFlow(surahNumber)
}
```


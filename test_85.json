{"verses":[{"id":1,"verse_number":1,"verse_key":"1:1","hizb_number":1,"rub_el_hizb_number":1,"ruku_number":1,"manzil_number":1,"sajdah_number":null,"text_uthmani":"بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ","page_number":1,"juz_number":1,"translations":[{"id":401704,"resource_id":85,"text":"In the name of God, the Lord of Mercy, the Giver of Mercy!"}]},{"id":2,"verse_number":2,"verse_key":"1:2","hizb_number":1,"rub_el_hizb_number":1,"ruku_number":1,"manzil_number":1,"sajdah_number":null,"text_uthmani":"ٱلْحَمْدُ لِلَّهِ رَبِّ ٱلْعَـٰلَمِينَ","page_number":1,"juz_number":1,"translations":[{"id":401705,"resource_id":85,"text":"Praise belongs to God, Lord of the Worlds,"}]},{"id":3,"verse_number":3,"verse_key":"1:3","hizb_number":1,"rub_el_hizb_number":1,"ruku_number":1,"manzil_number":1,"sajdah_number":null,"text_uthmani":"ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ","page_number":1,"juz_number":1,"translations":[{"id":401706,"resource_id":85,"text":"the Lord of Mercy, the Giver of Mercy,"}]},{"id":4,"verse_number":4,"verse_key":"1:4","hizb_number":1,"rub_el_hizb_number":1,"ruku_number":1,"manzil_number":1,"sajdah_number":null,"text_uthmani":"مَـٰلِكِ يَوْمِ ٱلدِّينِ","page_number":1,"juz_number":1,"translations":[{"id":401707,"resource_id":85,"text":"Master of the Day of Judgement."}]},{"id":5,"verse_number":5,"verse_key":"1:5","hizb_number":1,"rub_el_hizb_number":1,"ruku_number":1,"manzil_number":1,"sajdah_number":null,"text_uthmani":"إِيَّاكَ نَعْبُدُ وَإِيَّاكَ نَسْتَعِينُ","page_number":1,"juz_number":1,"translations":[{"id":401708,"resource_id":85,"text":"It is You we worship; it is You we ask for help."}]},{"id":6,"verse_number":6,"verse_key":"1:6","hizb_number":1,"rub_el_hizb_number":1,"ruku_number":1,"manzil_number":1,"sajdah_number":null,"text_uthmani":"ٱهْدِنَا ٱلصِّرَٰطَ ٱلْمُسْتَقِيمَ","page_number":1,"juz_number":1,"translations":[{"id":401709,"resource_id":85,"text":"Guide us to the straight path:"}]},{"id":7,"verse_number":7,"verse_key":"1:7","hizb_number":1,"rub_el_hizb_number":1,"ruku_number":1,"manzil_number":1,"sajdah_number":null,"text_uthmani":"صِرَٰطَ ٱلَّذِينَ أَنْعَمْتَ عَلَيْهِمْ غَيْرِ ٱلْمَغْضُوبِ عَلَيْهِمْ وَلَا ٱلضَّآلِّينَ","page_number":1,"juz_number":1,"translations":[{"id":401710,"resource_id":85,"text":"the path of those You have blessed, those who incur no anger and who have not gone astray."}]}],"pagination":{"per_page":10,"current_page":1,"next_page":null,"total_pages":1,"total_records":7}}
